{
    "name": "aqara-scrypted",
    "version": "1.0.4",
    "description": "Scrypted plugin for Aqara cameras (G410 and compatible models) via local RTSP",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "build": "scrypted-webpack",
        "lint": "eslint 'src/**/*.ts'",
        "dev": "scrypted-webpack --watch",
        "scrypted-debug": "scrypted-debug",
        "preinstall": "npx only-allow pnpm",
        "scrypted-deploy": "scrypted-deploy",
        "scrypted-readme": "scrypted-readme",
        "lint:fix": "eslint 'src/**/*.ts' --fix",
        "build:watch": "scrypted-webpack --watch",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "prescrypted-vscode-launch": "scrypted-webpack",
        "scrypted-deploy-debug": "scrypted-deploy-debug",
        "scrypted-package-json": "scrypted-package-json",
        "scrypted-vscode-launch": "scrypted-deploy-debug",
        "scrypted-setup-project": "scrypted-setup-project",
        "prescrypted-setup-project": "scrypted-package-json",
        "prepublishOnly": "NODE_ENV=production scrypted-webpack",
        "clean": "rm -rf dist out .scrypted .tsbuildinfo tsconfig.tsbuildinfo"
    },
    "keywords": [
        "scrypted",
        "aqara",
        "g410",
        "camera",
        "doorbell",
        "rtsp",
        "home-automation"
    ],
    "license": "MIT",
    "scrypted": {
        "rollup": false,
        "name": "Aqara Plugin",
        "type": "DeviceProvider",
        "interfaces": [
            "DeviceProvider",
            "DeviceCreator",
            "Settings"
        ]
    },
    "dependencies": {
        "@scrypted/sdk": "latest"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vitest": "^4.1.5"
    },
    "main": "out/main.nodejs.js",
    "files": [
        "out/",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DTse/aqara-scrypted.git"
    },
    "author": "DTse",
    "bugs": {
        "url": "https://github.com/DTse/aqara-scrypted/issues"
    },
    "homepage": "https://github.com/DTse/aqara-scrypted#readme"
}
